datasource db {
 provider = "sqlite"
  url      = "file:./dev.db"

}

generator client {
  provider = "prisma-client-js"
}

model Product {
   id          Int      @id @default(autoincrement())
  name        String

  description String?
  price       Float
  stock       Int      @default(0)
  image       String?


  category   String

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
